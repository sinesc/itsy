// Array iteration over heap-reference elements (Strings).
// Exercises: heap_fetch_elementx, heap_ceq_16

fn setup() -> [ String ] {
    let arr: [ String ] = [];
    for i in 0..100 {
        arr.push(i as String);
    }
    arr
}

fn bench(arr: [ String ]) {
    let mut count = 0;
    for _ in 0..150 {
        for s in arr {
            if s == "42" { count += 1; }
        }
    }
    let _ = count;
}
