// Array iteration over u8 elements.
// Exercises: array_iter8, heap_fetch_element8

fn setup() -> [ u8 ] {
    let arr: [ u8 ] = [];
    for i in 0..256 {
        arr.push(i as u8);
    }
    arr
}

fn bench(arr: [ u8 ]) {
    let mut sum = 0;
    for _ in 0..175 {
        for v in arr {
            sum += v as i32;
        }
    }
    let _ = sum;
}
